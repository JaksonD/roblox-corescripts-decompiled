    ["Feature.NotApproved.Description.RuleExplanation.BullyingHarassmentDiscrimination"] = "Birine veya ba\197\159ka biri hakk\196\177nda k\195\182t\195\188 \197\159eyler s\195\182ylemek asla kabul edilemez. Buna, \195\182zel bilgilerini payla\197\159ma veya ger\195\167ek hayatta ona zarar verme gibi tehditlerde bulunmak da d\195\162hildir. \nBirine k\195\182t\195\188 davranmak veya kim oldu\196\159u, neye inand\196\177\196\159\196\177 ya da nereden geldi\196\159i ile ilgili olarak onu d\196\177\197\159lamak da kurallara ayk\196\177r\196\177d\196\177r.", 
    ["Feature.NotApproved.Description.RuleExplanation.Dating"] = "Sohbet ederken arkada\197\159 canl\196\177s\196\177 ol, fl\195\182rt etme. \195\150p\195\188\197\159me veya fl\195\182rt gibi romantik davran\196\177\197\159lara izin verilmez. Avatar k\196\177yafetlerinin \195\167ok a\195\167\196\177k olmamas\196\177 da \195\182nemlidir.", 
    ["Feature.NotApproved.Description.RuleExplanation.DirectingUsersOffPlatform"] = "Sohbette ba\197\159ka web sitelerine ba\196\159lant\196\177 payla\197\159mak ya da ba\197\159ka uygulamalardaki veya sosyal medyadaki profilinin nas\196\177l bulunabilece\196\159ini a\195\167\196\177klamak kurallara ayk\196\177r\196\177d\196\177r. Seni ba\197\159ka bir web sitesine y\195\182nlendirmeye \195\167al\196\177\197\159\196\177rlarsa kabul etme. Sohbetlerini ve oyunlar\196\177n\196\177 Roblox'ta s\195\188rd\195\188rmeli, d\196\177\197\159ar\196\177ya ta\197\159\196\177mamal\196\177s\196\177n.\nAyr\196\177ca Roblox d\196\177\197\159\196\177nda Robux veya Roblox \195\182\196\159eleri sat\196\177n almak, satmak ya da takas etmek kabul edilemez.", 
    ["Feature.NotApproved.Description.RuleExplanation.MisusingRobloxSystems"] = "Roblox'ta hile yapmak, yalan s\195\182ylemek veya bunu yapman\196\177n yollar\196\177n\196\177 payla\197\159mak kurallara ayk\196\177r\196\177d\196\177r. \195\150rne\196\159in:", 
    ["Feature.NotApproved.Description.RuleExplanation.PII"] = "Herkesin ve t\195\188m hesaplar\196\177n g\195\188vende olmas\196\177n\196\177 sa\196\159lamak amac\196\177yla, a\197\159a\196\159\196\177daki gibi \195\182zel bilgileri istemek veya payla\197\159mak kurallara ayk\196\177r\196\177d\196\177r:", 
    ["Feature.NotApproved.Description.RuleExplanation.RealLifeEvents"] = "Ger\195\167ek hayatta meydana gelen belirli anlara kar\197\159\196\177 sayg\196\177s\196\177zl\196\177k yapmak kurallara ayk\196\177r\196\177d\196\177r. Bu, \195\182zellikle bir\195\167ok insan i\195\167in \195\188z\195\188c\195\188 veya korkutucu olan olaylar\196\177 ya da bu olaylara d\195\162hil olan insanlar\196\177 yeniden canland\196\177rmay\196\177 veya bunlarla dalga ge\195\167meyi i\195\167erir.\nBu olaylara \197\159unlar d\195\162hildir:", 
    ["Feature.NotApproved.Description.RuleExplanation.SSHAndIllegalRegulatedActivities"] = "A\197\159a\196\159\196\177daki gibi tehlikeli veya zararl\196\177 \197\159eyler hakk\196\177nda i\195\167erik olu\197\159turmak, sohbet etmek ya da \197\159aka yapmak asla kabul edilemez:", 
    ["Feature.NotApproved.Description.RuleExplanation.Spam"] = "Mesajlarda ayn\196\177 kelimeleri tekrar tekrar g\195\182ndermek asla kabul edilemez.", 
    ["Feature.NotApproved.Description.RuleExplanation.Swearing"] = "K\195\188f\195\188rl\195\188 kelimeler kullanmak asla kabul edilemez. Buna, alg\196\177lama sistemlerini atlatmak i\195\167in yanl\196\177\197\159 yaz\196\177m, semboller veya ba\197\159ka y\195\182ntemler kullanmak da d\195\162hildir.", 
    ["Feature.NotApproved.Description.RuleExplanation.ViolentContentAndGore"] = "Ger\195\167ek\195\167i \197\159iddet veya bir ki\197\159inin, hayvan\196\177n ya da karakterin ciddi \197\159ekilde fiziksel veya duygusal olarak zarar g\195\182rd\195\188\196\159\195\188n\195\188 g\195\182steren herhangi bir \197\159eyi payla\197\159mak kurallara ayk\196\177r\196\177d\196\177r.", 
    ["Feature.NotApproved.Description.RuleImportance.BullyingHarassmentDiscrimination"] = "Toplulu\196\159umuzu herkes i\195\167in e\196\159lenceli k\196\177lmak amac\196\177yla, birini g\195\188vensiz veya rahats\196\177z hissettiren kelimeler ya da eylemler kullanmay\196\177z. Roblox t\195\188m \196\177rklara, etnik k\195\182kenlere, cinsel kimliklere, yeteneklere, cinsel y\195\182nelimlere ve dinlere sayg\196\177l\196\177d\196\177r.", 
    ["Feature.NotApproved.Description.RuleImportance.Dating"] = "Sohbetlerin ve avatarlar\196\177n arkada\197\159l\196\177k \195\167er\195\167evesinde kalmas\196\177, herkesin kendini rahat hissetmesine yard\196\177mc\196\177 olur.", 
    ["Feature.NotApproved.Description.RuleImportance.DirectingUsersOffPlatform"] = "Roblox, sohbet ve etkile\197\159imde g\195\188venli\196\159i sa\196\159lamak i\195\167in koruyucu \195\182nlemler uygular. Hesab\196\177n\196\177 ve \195\182\196\159elerini \195\167alma amac\196\177yla seni Roblox gibi g\195\182r\195\188nen sahte web sitelerine y\195\182nlendirecek ba\196\159lant\196\177larla kar\197\159\196\177la\197\159abilirsin. Ayr\196\177ca bu sitelerde uygunsuz resimler veya videolar olabilir. Roblox d\196\177\197\159\196\177nda Robux veya \195\182\196\159e kullanarak takas yaparsan kar\197\159\196\177ndakiler sana yalan s\195\182yleyebilir ve vadettiklerini vermeyebilir.", 
    ["Feature.NotApproved.Description.RuleImportance.MisuingRobloxSystems"] = "Hepimiz kurallara uyup d\195\188r\195\188st\195\167e oynad\196\177\196\159\196\177m\196\177zda Roblox herkes i\195\167in e\196\159lenceli kal\196\177r, b\195\182ylece kimsenin haks\196\177z bir avantaj\196\177 olmaz.", 
    ["Feature.NotApproved.Description.RuleImportance.MisusingRobloxSystems"] = "Hepimiz kurallara uyup d\195\188r\195\188st\195\167e oynad\196\177\196\159\196\177m\196\177zda Roblox herkes i\195\167in e\196\159lenceli kal\196\177r, b\195\182ylece kimsenin haks\196\177z bir avantaj\196\177 olmaz.", 
