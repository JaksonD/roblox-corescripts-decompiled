	["Feature.NotApproved.Description.ReviewProcess"] = "हम टेक्नोलॉजी और लोगों की मदद से, आपकी ऐक्टिविटी रिव्यू करते हैं.",
	["Feature.NotApproved.Description.RuleExplanation.Bullets.MisusingRobloxSystems"] = "किसी और की नकल करना\nऐसी चीज़ों के लिए यूज़र को रिपोर्ट करना जो हुई ही नहीं हैं\nलोगों को धोखा देने के लिए झूठ बोलना\nदूसरों के अकाउंट में सेंधमारी की कोशिश करना\nRoblox को सुरक्षित रखने वाले नियमों से बचने के लिए एक नया Roblox अकाउंट बनाना",
	["Feature.NotApproved.Description.RuleExplanation.Bullets.PII"] = "नाम, पते, फ़ोन नंबर, ईमेल\nअन्य अकाउंट के यूज़रनेम \nपासवर्ड",
	["Feature.NotApproved.Description.RuleExplanation.Bullets.RealLifeEvents"] = "ऐसी हिंसक घटना, जिसमें कई लोगों को चोट लगी हो या बहुत नुकसान हुआ हो\nभयानक दुर्घटनाएँ या प्राकृतिक आपदाएँ जैसे कि भूकंप, तूफ़ान और टॉर्नेडो\nसुर्खियों में आई झकझोर देने वाली अपराधिक घटनाएँ\nअसल ज़िंदगी की वे घटनाएँ, जिनमें लोगों के साथ बुरा बर्ताव या नाइंसाफ़ी हुई हो",
	["Feature.NotApproved.Description.RuleExplanation.Bullets.SSHAndIllegalRegAct"] = "खुद को या दूसरों को चोट पहुँचाने के तरीके\nखतरनाक शारीरिक चुनौतियाँ, जिनमें असल ज़िंदगी के ऑनलाइन ट्रेंड शामिल हैं\nअवैध या खतरनाक चीज़ें, जैसे कि शराब और नशीली दवाएँ\nजुआ, सट्टेबाज़ी या इनाम जीतने के लिए खेले जाने वाले गेम\nअसल ज़िंदगी में हथियार बनाने के निर्देश",
	["Feature.NotApproved.Description.RuleExplanation.BullyingHarassmentDiscrimination"] = "किसी के सामने या किसी के बारे में बुरी बातें कहना कभी भी सही नहीं होता. इसमें उन्हें नुकसान पहुँचाने की धमकी देना शामिल है, जैसे कि उनकी निजी जानकारी शेयर करना या असल ज़िंदगी में उन्हें चोट पहुँचाना. \nकिसी के साथ बुरा बर्ताव करना या उनकी पहचान, उनकी मान्यताओं या उनके मूल के आधार पर उन्हें अलग-थलग करना भी नियमों के खिलाफ़ है.",
	["Feature.NotApproved.Description.RuleExplanation.Dating"] = "चैट करते समय दोस्ताना व्यवहार करें और फ़्लर्ट न करें. किसिंग या डेटिंग जैसे रोमैंटिक व्यवहार की अनुमति नहीं है. यह भी ज़रूरी है कि अवतार की ड्रेस ऐसी न हो, जिससे बहुत ज़्यादा शरीर दिखे.",
	["Feature.NotApproved.Description.RuleExplanation.DirectingUsersOffPlatform"] = "चैट में अन्य वेबसाइट के लिंक शेयर करना या लोगों को अन्य ऐप या सोशल मीडिया पर आपकी प्रोफ़ाइल खोजने के बारे में बताना नियमों के खिलाफ़ है. अगर कोई आपको किसी अन्य वेबसाइट पर जाने के लिए कहता है, तो आपको ऐसा नहीं करना चाहिए. अपनी बातचीत और गेमप्ले को Roblox पर ही रखें.\nRoblox के बाहर Robux या Roblox के आइटम खरीदना, बेचना या ट्रेड करना भी सही नहीं है.",
	["Feature.NotApproved.Description.RuleExplanation.MisusingRobloxSystems"] = "Roblox पर जालसाज़ी करना या झूठ बोलना या ऐसा करने के तरीके शेयर करना नियमों के खिलाफ़ है. उदाहरण के लिए:",
	["Feature.NotApproved.Description.RuleExplanation.PII"] = "सभी लोगों और उनके अकाउंट को सुरक्षित रखने के लिए, निजी जानकारी माँगना या शेयर करना नियमों के खिलाफ़ है, जैसे :",
	["Feature.NotApproved.Description.RuleExplanation.RealLifeEvents"] = "असल दुनिया में हुई किसी खास घटना को अनुचित तरीके से पेश करना नियमों के खिलाफ़ है. इसमें किसी घटना को रीक्रिएट करना या उसका मज़ाक बनाना या उसका हिस्सा रहे लोगों का मज़ाक उड़ाना भी शामिल है, खासकर जब वे घटनाएँ बहुत से लोगों के लिए दुखद या डरावनी हों.\nइनमें ये शामिल हैं :",
	["Feature.NotApproved.Description.RuleExplanation.SSHAndIllegalRegulatedActivities"] = "खतरनाक या हानिकारक चीज़ों के बारे में कॉन्टेंट बनाना, चैट करना या मज़ाक करना कभी भी स्वीकार्य नहीं है, जैसे :",
	["Feature.NotApproved.Description.RuleExplanation.Spam"] = "एक ही मैसेज बार-बार भेजना कभी भी सही नहीं होता.",
	["Feature.NotApproved.Description.RuleExplanation.Swearing"] = "अपशब्दों का इस्तेमाल करना कभी भी सही नहीं होता. इसमें डिटेक्शन सिस्टम से बचने के लिए गलत स्पेलिंग, चिह्नों या अन्य तरीकों का इस्तेमाल करना शामिल है.",
	["Feature.NotApproved.Description.RuleExplanation.ViolentContentAndGore"] = "असल रूप में हिंसा दिखाना या किसी व्यक्ति, जानवर या कैरेक्टर को गंभीर रूप से शारीरिक या भावनात्मक रूप से आहत दिखाना नियमों के खिलाफ़ है.",
	["Feature.NotApproved.Description.RuleImportance.BullyingHarassmentDiscrimination"] = "हमारी कम्यूनिटी सभी के लिए मज़ेदार बनी रहे, इसके लिए हम ऐसे शब्दों या ऐसी गतिविधियों का इस्तेमाल नहीं करते, जिनसे किसी को असुरक्षित या असहज महसूस हो. Roblox नस्लों, जातियों, जेंडर आइडेंटिटी, क्षमताओं, यौन रुझानों और धर्मों के आधार पर लोगों में भेदभाव नहीं करता है.",
	["Feature.NotApproved.Description.RuleImportance.Dating"] = "अवतारों और चैट को दोस्ती पर केंद्रित रखने से यह पक्का करने में मदद मिलती है कि हर कोई सहज महसूस करे.",
	["Feature.NotApproved.Description.RuleImportance.DirectingUsersOffPlatform"] = "Roblox ने आपकी चैट और इंटरैक्शन को सुरक्षित रखने के लिए सुरक्षा उपाय अपनाए हैं. लिंक आपको Roblox जैसी दिखने वाली नकली वेबसाइट पर ले जा सकते हैं, जो आपके अकाउंट और आइटम चुरा सकती हैं. इन साइट पर अनुचित तस्वीरें या वीडियो भी हो सकते हैं. Roblox के बाहर Robux या आइटम ट्रेड करने पर, हो सकता है कि लोग आपसे झूठ बोलें और आपसे किया वादा पूरा न करें.",
	["Feature.NotApproved.Description.RuleImportance.MisuingRobloxSystems"] = "जब हम सभी नियमों का पालन करते हैं और ईमानदारी से खेलते हैं, तो Roblox सभी के लिए मज़ेदार बना रहता है, और किसी को भी गलत तरीके से कोई फ़ायदा नहीं मिलता.",
	["Feature.NotApproved.Description.RuleImportance.MisusingRobloxSystems"] = "जब हम सभी नियमों का पालन करते हैं और ईमानदारी से खेलते हैं, तो Roblox सभी के लिए मज़ेदार बना रहता है, ताकि किसी को भी गलत तरीके से कोई फ़ायदा न मिल पाए.",
	["Feature.NotApproved.Description.RuleImportance.PII"] = "अगर किसी अजनबी को असल ज़िंदगी में आपकी पहचान का पता चल जाए, तो वे Roblox के बाहर आपसे संपर्क करने की कोशिश कर सकते हैं. यह खतरनाक हो सकता है, क्योंकि ऑनलाइन यह पता नहीं किया जा सकता कि कौन अच्छा है और कौन बुरा. यही वजह है कि हम कभी भी पासवर्ड शेयर नहीं करते. कोई आपका अकाउंट और आपकी कमाई चीज़ें चुरा सकता है.",
	["Feature.NotApproved.Description.RuleImportance.RealLifeEvents"] = "जिन लोगों ने इन घटनाओं का सामना किया है, उनके लिए इन्हें रीक्रिएट करना या मज़ाक बनाया जाना बहुत परेशान करने वाला हो सकता है.",
	["Feature.NotApproved.Description.RuleImportance.SSHAndIllegalRegulatedActivities"] = "खुद को या दूसरों को चोट पहुँचाने से जुड़ा कॉन्टेंट शेयर करना सुरक्षित नहीं है. अगर आप मुश्किल दौर से गुज़र रहे हैं, तो किसी ऐसे वयस्क से बात करना ज़रूरी है, जिस पर आपको भरोसा हो. खतरनाक स्टंट जैसी चीज़ें शेयर करने से दूसरे उन्हें आज़माने के लिए प्रेरित हो सकते हैं और उन्हें गंभीर चोट लग सकती है. इन चीज़ों को शेयर न करके, आप खुद को और Roblox पर मौजूद हर किसी को सुरक्षित रखने में मदद करते हैं.",
	["Feature.NotApproved.Description.RuleImportance.Spam"] = "स्पैमिंग की वजह से बातचीत को समझना मुश्किल हो जाता है और मज़ा भी किरकिरा हो जाता है.",
	["Feature.NotApproved.Description.RuleImportance.Swearing"] = "Roblox छोटे बच्चों सहित सभी के लिए है. हम ऐसे शब्दों का इस्तेमाल करते हैं, जो हमारी पूरी कम्यूनिटी के लिए सम्मानजनक और स्वागत योग्य हों.",
	["Feature.NotApproved.Description.RuleImportance.ViolentContentAndGore"] = "हमारी कम्यूनिटी में छोटे बच्चे भी शामिल हैं और बहुत ज़्यादा हिंसा देखना उनके लिए डरावना और परेशान करने वाला हो सकता है.",
