	["Feature.NotApproved.Description.ReviewProcess"] = "نراجع نشاطك باستخدام التقنية والأشخاص معًا.",
	["Feature.NotApproved.Description.RuleExplanation.Bullets.MisusingRobloxSystems"] = "التظاهر بأنك شخص آخر\nالإبلاغ عن المستخدمين لأشياء لم تحدث\nالكذب على الأشخاص لخداعهم للقيام بشيء ما\nمحاولة الدخول إلى حسابات الأشخاص الآخرين\nإنشاء حساب جديد على منصّة Roblox للتحايل على القواعد التي تحافظ على أمان منصّة Roblox",
	["Feature.NotApproved.Description.RuleExplanation.Bullets.PII"] = "الأسماء والعناوين وأرقام الهواتف وعناوين البريد الإلكتروني\nأسماء المستخدمين في الحسابات الأخرى \nكلمات المرور",
	["Feature.NotApproved.Description.RuleExplanation.Bullets.RealLifeEvents"] = "العنف الذي ألحق أذىً بعدد كبير من الأشخاص أو تسبب في أضرار واسعة النطاق\nالحوادث المروّعة أو الكوارث الطبيعية مثل الزلازل، والأعاصير، والزوابع\nالجرائم الصادمة المذكورة في الأخبار\nالأحداث في الحياة الواقعية التي يتعرض فيها مجموعات من الناس للقسوة أو الظلم",
	["Feature.NotApproved.Description.RuleExplanation.Bullets.SSHAndIllegalRegAct"] = "طرق لإيذاء نفسك أو الآخرين\nالتحديات الجسدية الخطرة، بما في ذلك الصيحات المنتشرة أون لاين وتُمارس في العالم الواقعي\nالأشياء غير القانونية أو الخطرة مثل الكحول والمخدرات\nالقمار أو المراهنات أو الألعاب التي تعتمد على الحظ للفوز بالجوائز\nالتعليمات لصناعة الأسلحة في العالم الواقعي",
	["Feature.NotApproved.Description.RuleExplanation.BullyingHarassmentDiscrimination"] = "لا يُسمح أبدًا بإهانة الآخرين أو قول أشياء مؤذية عن شخص آخر. يشمل ذلك التهديد بإلحاق الضرر به، مثل مشاركة معلوماته الخاصة أو إيذائه في الحياة الواقعية. \nكما أنّه مخالف للقواعد أن تعامل شخصًا ما بقسوة أو تستبعده بسبب هويته أو معتقداته أو أصله.",
	["Feature.NotApproved.Description.RuleExplanation.Dating"] = "عند الدردشة، احرص على أن تكون ودودًا وتجنّب المغازلة. السلوكيات الرومانسية مثل التقبيل أو المواعدة غير مسموح بها. ومن المهم ألا تكون ثياب الأفاتار كاشفة للغاية.",
	["Feature.NotApproved.Description.RuleExplanation.DirectingUsersOffPlatform"] = "تُمنع مشاركة الروابط إلى المواقع الإلكترونية الأخرى في الدردشة أو إخبار الأشخاص الآخرين بكيفية العثور على ملفك الشخصي في التطبيقات أو منصات التواصل الاجتماعي الأخرى. إذا طلب منك أحدهم الانتقال إلى موقع إلكتروني آخر، فلا تفعل ذلك واحرص على إبقاء محادثاتك وطريقة لعبك ضمن منصّة Roblox دائمًا.\nكما لا يُسمح بشراء أو بيع أو تبادل عملات Robux أو عناصر Roblox خارج منصّة Roblox.",
	["Feature.NotApproved.Description.RuleExplanation.MisusingRobloxSystems"] = "من المخالف للقواعد الغش أو الكذب أو مشاركة طرق الغش على منصّة Roblox. على سبيل المثال:",
	["Feature.NotApproved.Description.RuleExplanation.PII"] = "للحفاظ على سلامة الجميع وحساباتهم، يُمنع طلب أو مشاركة المعلومات الخاصة، مثل:",
	["Feature.NotApproved.Description.RuleExplanation.RealLifeEvents"] = "من المخالف للقواعد عدم احترام لحظات معينة حدثت في العالم الواقعي. يشمل ذلك إعادة تمثيل الأحداث أو السخرية منها أو من الأشخاص الذين يظهرون فيها، خاصة عندما تكون محزنة أو مخيفة بالنسبة إلى كثير من الناس.\nويشمل ذلك:",
	["Feature.NotApproved.Description.RuleExplanation.SSHAndIllegalRegulatedActivities"] = "لا يجوز أبدًا إنشاء محتوى أو التحدث في الدردشة أو المزاح حول السلوكيات أو الأفعال الخطرة أو الضارة، مثل:",
	["Feature.NotApproved.Description.RuleExplanation.Spam"] = "لا يُسمح بإرسال نفس الكلمات مرارًا وتكرارًا.",
	["Feature.NotApproved.Description.RuleExplanation.Swearing"] = "لا يجوز أبدًا استخدام الكلمات والألفاظ البذيئة. ويشمل ذلك محاولة التحايل على أنظمة الكشف باستخدام التهجئات الخاطئة، أو الرموز، أو أي طرق أخرى.",
	["Feature.NotApproved.Description.RuleExplanation.ViolentContentAndGore"] = "يُعد عرض العنف الواقعي أو أي شيء يوحي بأن شخصًا أو حيوانًا أو شخصية تتعرض لأذى جسدي أو عاطفي شديد مخالفًا للقواعد.",
	["Feature.NotApproved.Description.RuleImportance.BullyingHarassmentDiscrimination"] = "لكي يظل مجتمعنا مكانًا ممتعًا يشعر فيه الجميع بالترحيب، نحرص على عدم استخدام كلمات أو تصرّفات قد تُزعج الآخرين أو تجعلهم يشعرون بعدم الأمان. تجمع منصّة Roblox أشخاصًا من مختلف الأعراق والثقافات والهويات الجنسية والقدرات والتوجهات والديانات.",
	["Feature.NotApproved.Description.RuleImportance.Dating"] = "إبقاء الدردشات والأفاتارات في إطار الصداقات يساعد الجميع على الشعور بالراحة.",
	["Feature.NotApproved.Description.RuleImportance.DirectingUsersOffPlatform"] = "توفّر منصّة Roblox إجراءات للسلامة للمساعدة في الحفاظ على أمان الدردشات والتفاعلات. قد تنقلك الروابط إلى مواقع ويب مزيفة تحاكي منصّة Roblox بهدف خداعك وسرقة حسابك وعناصرك. وقد تعرض هذه المواقع أيضًا صورًا أو مقاطع فيديو غير لائقة. وإذا قمت بتبادل عملات Robux أو العناصر خارج منصّة Roblox، فقد يخدعك الأشخاص ولا يقدّمون لك ما وعدوا به.",
	["Feature.NotApproved.Description.RuleImportance.MisuingRobloxSystems"] = "تظل منصّة Roblox مكانًا ممتعًا للجميع عند اتِّباعنا جميعًا للقواعد واللعب بأمانة، حتى لا يحصل أحد على ميزة غير عادلة.",
	["Feature.NotApproved.Description.RuleImportance.MisusingRobloxSystems"] = "تظل منصّة Roblox مكانًا ممتعًا للجميع عند اتِّباعنا جميعًا للقواعد واللعب بأمانة، حتى لا يحصل أحد على ميزة غير عادلة.",
	["Feature.NotApproved.Description.RuleImportance.PII"] = "إذا تمكن شخص غريب من معرفة هويتك في الحياة الواقعية، فقد يحاول التواصل معك خارج منصّة Roblox، وهذا قد يعرّضك للخطر. فمن الصعب أون لاين التأكد ممّا إذا كان الشخص فعلًا جديرًا بالثقة أم لا. لذلك، لا نشارك أبدًا كلمة مرورك أو أي معلومات شخصية. فقد يتمكّن شخص ما من الاستيلاء على حسابك وكل ما كسبته.",
	["Feature.NotApproved.Description.RuleImportance.RealLifeEvents"] = "بالنسبة إلى شخص مر بهذه الأشياء، فإن رؤيته لإعادة تمثيلها أو السخرية منها، قد يكون أمرًا مزعجًا جدًا.",
	["Feature.NotApproved.Description.RuleImportance.SSHAndIllegalRegulatedActivities"] = "مشاركة المحتوى حول إيذاء نفسك أو الآخرين لا يُعد أمرًا آمنًا. إذا كنت تمر بوقت عصيب، فمن المهم التحدث إلى شخص بالغ تثق به. فقد تشجّع أشياء مثل الأعمال الخطرة الآخرين على تجربتها والتعرّض لإصابات خطيرة. بعدم مشاركة هذا المحتوى، فإنك تساعد في حماية نفسك وكل الأشخاص على منصّة Roblox.",
	["Feature.NotApproved.Description.RuleImportance.Spam"] = "إرسال الرسائل غير المرغوب فيها يجعل متابعة المحادثة صعبًا ويُعكّر أجواء المرح.",
	["Feature.NotApproved.Description.RuleImportance.Swearing"] = "منصّة Roblox مخصّصة للجميع، بما في ذلك الأطفال الصغار. نحرص على استخدام كلمات محترمة ومرحّبة لضمان أن تكون مناسبة لجميع أفراد المجتمع.",
	["Feature.NotApproved.Description.RuleImportance.ViolentContentAndGore"] = "يضم مجتمعنا أطفالًا صغارًا، لذا قد تكون مشاهدة العنف الشديد مخيفة ومزعجة لهم.",
	["Feature.NotApproved.Description.SecondChance.Details"] = "يمكنك الرجوع إلى اللعب الآن. لن تتمكّن من استئناف هذا القرار لاحقًا.",
