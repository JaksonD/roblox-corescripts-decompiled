    ["Feature.NotApproved.Description.ReactivationNotice"] = "Select \226\128\152Continue\226\128\153 to review our rules and you can play right after that.", 
    ["Feature.NotApproved.Description.ReviewProcess"] = "We review your activity using both technology and people.", 
    ["Feature.NotApproved.Description.RuleExplanation.Bullets.MisuingRobloxSystems"] = "Pretending to be someone you\226\128\153re not\nReporting users for things that didn\226\128\153t happen\nLying to trick people into doing something\nTrying to get into other people\226\128\153s accounts\nCreating a new Roblox account to get around rules that keep Roblox safe", 
    ["Feature.NotApproved.Description.RuleExplanation.Bullets.MisusingRobloxSystems"] = "Pretending to be someone you\226\128\153re not\nReporting users for things that didn\226\128\153t happen\nLying to trick people into doing something\nTrying to get into other people\226\128\153s accounts\nCreating a new Roblox account to get around rules that keep Roblox safe", 
    ["Feature.NotApproved.Description.RuleExplanation.Bullets.PII"] = "Names, addresses, phone numbers, emails\nUsernames on other accounts \nPasswords", 
    ["Feature.NotApproved.Description.RuleExplanation.Bullets.RealLifeEvents"] = "Violence that hurt many people or caused a lot of damage\nTerrible accidents or natural disasters such as earthquakes, hurricanes, and tornadoes\nShocking crimes in the news\nReal-life events where groups of people are treated cruelly or unfairly", 
    ["Feature.NotApproved.Description.RuleExplanation.Bullets.SSHAndIllegalRegAct"] = "Ways to hurt yourself or others\nDangerous physical challenges including online trends in the real world\nThings that are illegal or dangerous such as alcohol and drugs\nGambling, betting or games of chance for prizes\nInstructions for making weapons in the real world", 
    ["Feature.NotApproved.Description.RuleExplanation.BullyingHarassmentDiscrimination"] = "It\226\128\153s never okay to say mean things to someone or about another person. This includes threatening to harm them, such as by sharing their private information or hurting them in real life. \nIt\226\128\153s also against the rules to be mean to someone or exclude them because of who they are, what they believe, or where they come from.", 
    ["Feature.NotApproved.Description.RuleExplanation.Dating"] = "When you chat, keep it friendly and not flirty. Romantic behaviors like kissing or dating are not allowed. It\226\128\153s also important that avatar clothes aren't too revealing.", 
    ["Feature.NotApproved.Description.RuleExplanation.DirectingUsersOffPlatform"] = "It's against the rules to share links in chat to other websites or tell people how to find your profile on other apps or social media. If someone tells you to go to another website, you shouldn't do it. Keep your conversations and gameplay on Roblox.\nIt's also not okay to buy, sell, or trade Robux or Roblox items outside of Roblox.", 
    ["Feature.NotApproved.Description.RuleExplanation.MisuingRobloxSystems"] = "It\226\128\153s against the rules to cheat or lie or share ways to do that on Roblox. For example:", 
    ["Feature.NotApproved.Description.RuleExplanation.MisusingRobloxSystems"] = "It\226\128\153s against the rules to cheat or lie or share ways to do that on Roblox. For example:", 
    ["Feature.NotApproved.Description.RuleExplanation.PII"] = "To keep everyone and their accounts safe, it\226\128\153s against the rules to ask for or share private information, such as:", 
    ["Feature.NotApproved.Description.RuleExplanation.RealLifeEvents"] = "It\226\128\153s against the rules to be disrespectful about specific moments that happened in the real world. This includes recreating or making fun of events or the people in them, especially when they\226\128\153re sad or scary for a lot of people.\nThis includes:", 
    ["Feature.NotApproved.Description.RuleExplanation.SSHAndIllegalRegulatedActivities"] = "It\226\128\153s never acceptable to create content, chat or joke about dangerous or harmful things, such as:", 
    ["Feature.NotApproved.Description.RuleExplanation.Spam"] = "It\226\128\153s never okay to keep messaging the same words over and over again.", 
    ["Feature.NotApproved.Description.RuleExplanation.Swearing"] = "It\226\128\153s never OK to use swear words. This includes using misspellings, symbols, or other methods to try to get around detection systems.", 
    ["Feature.NotApproved.Description.RuleExplanation.ViolentContentAndGore"] = "It\226\128\153s against the rules to show realistic violence or anything that makes it look like a person, animal or character is seriously physically or emotionally hurt.", 
    ["Feature.NotApproved.Description.RuleImportance.BullyingHarassmentDiscrimination"] = "To keep our community fun for everyone, we don\226\128\153t use words or actions that make someone feel unsafe or uncomfortable. Roblox is for all races, ethnicities, gender identities, abilities, sexual orientations, and religions.", 
    ["Feature.NotApproved.Description.RuleImportance.Dating"] = "Keeping chats and avatars focused on friendships helps make sure everyone feels comfortable.", 
    ["Feature.NotApproved.Description.RuleImportance.DirectingUsersOffPlatform"] = "Roblox has safety protections to try to keep chats and interactions safe. Links can take you to fake websites that look just like Roblox to steal your account and items. The sites could also have pictures or videos that are inappropriate. If you trade Robux or items outside of Roblox, people can lie and not give you what they promised.", 
    ["Feature.NotApproved.Description.RuleImportance.MisuingRobloxSystems"] = "Roblox stays fun for everyone when we all follow rules and play honestly, so that no one has an unfair advantage.", 
    ["Feature.NotApproved.Description.RuleImportance.MisusingRobloxSystems"] = "Roblox stays fun for everyone when we all follow rules and play honestly, so that no one has an unfair advantage.", 
    ["Feature.NotApproved.Description.RuleImportance.PII"] = "If a stranger figures out who you are in real life, they can try to contact you outside of Roblox. This can be dangerous because it\226\128\153s hard to know online if someone is good or bad. That\226\128\153s why we also never share passwords. Someone can steal your account and everything you\226\128\153ve earned.", 
    ["Feature.NotApproved.Description.RuleImportance.RealLifeEvents"] = "For someone who went through these things, seeing them recreated or joked about can be very upsetting.", 
    ["Feature.NotApproved.Description.RuleImportance.SSHAndIllegalRegulatedActivities"] = "Sharing content about hurting yourself or others isn\226\128\153t safe. If you're having a tough time, it's important to talk to an adult that you trust. Things like sharing dangerous stunts can inspire others to try them and get seriously hurt. By not sharing this stuff, you're helping to keep yourself and everyone on Roblox safe.", 
    ["Feature.NotApproved.Description.RuleImportance.Spam"] = "Spamming makes it hard to follow conversations and disrupts the fun.", 
    ["Feature.NotApproved.Description.RuleImportance.Swearing"] = "Roblox is for everyone, including young kids. We use words that are respectful and welcoming for our entire community.", 
    ["Feature.NotApproved.Description.RuleImportance.ViolentContentAndGore"] = "Our community includes young kids and seeing extreme violence can be scary and upsetting for them.", 
    ["Feature.NotApproved.Description.SecondChance.Details"] = "You can go back to playing now. You won\226\128\153t be able to appeal this decision later.", 
    ["Feature.NotApproved.Description.SecondChance.Second"] = "You can avoid a suspension this one time because you\226\128\153ve behaved responsibly in the past.", 
    ["Feature.NotApproved.Description.Violation"] = "Our content monitors have determined that your behavior at Roblox has been in violation of our {startLink}Terms of Use{endLink}.", 
