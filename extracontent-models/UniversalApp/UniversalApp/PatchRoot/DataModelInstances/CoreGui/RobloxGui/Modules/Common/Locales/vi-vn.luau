	["Feature.NotApproved.Description.Mistake"] = "Bạn có thể khiếu nại hoặc yêu cầu chúng tôi xem xét lại quyết định này tại đây.",
	["Feature.NotApproved.Description.Mistake.V2"] = "Có phải chúng tôi đã nhầm lẫn? Bạn có thể khiếu nại hoặc yêu cầu chúng tôi xem xét lại quyết định này tại đây.",
	["Feature.NotApproved.Description.Mistake.V3"] = "Nếu cho rằng chúng tôi có nhầm lẫn, bạn có thể khiếu nại quyết định này.",
	["Feature.NotApproved.Description.PluralViolation"] = "Một trong những {type} của bạn",
	["Feature.NotApproved.Description.ReactivationNotice"] = "Chọn \"Tiếp tục\" để xem lại các quy tắc của chúng tôi. Sau đó, bạn có thể chơi ngay.",
	["Feature.NotApproved.Description.ReviewProcess"] = "Chúng tôi sử dụng cả công nghệ và con người để xem xét hoạt động của bạn.",
	["Feature.NotApproved.Description.RuleExplanation.Bullets.MisusingRobloxSystems"] = "Giả mạo danh tính\nBáo cáo người dùng khác về những việc không hề xảy ra\nNói dối để lừa người khác làm điều gì đó\nCố gắng xâm nhập vào tài khoản của người khác\nTạo tài khoản Roblox mới để né tránh các quy tắc được đặt ra để giữ an toàn cho Roblox",
	["Feature.NotApproved.Description.RuleExplanation.Bullets.PII"] = "Tên, địa chỉ, số điện thoại, email\nTên người dùng của các tài khoản khác \nMật khẩu",
	["Feature.NotApproved.Description.RuleExplanation.Bullets.RealLifeEvents"] = "Hành vi bạo lực khiến nhiều người bị thương hoặc gây ra thiệt hại lớn\nCác vụ tai nạn thảm khốc hoặc thiên tai như động đất, bão và lốc xoáy\nCác vụ án gây chấn động được đưa tin\nCác sự kiện ngoài đời thực liên quan đến những nhóm người bị đối xử tàn nhẫn hoặc bất công",
	["Feature.NotApproved.Description.RuleExplanation.Bullets.SSHAndIllegalRegAct"] = "Cách làm hại bản thân hoặc người khác\nThử thách thể chất nguy hiểm bao gồm các xu hướng trực tuyến trong thế giới thực\nNhững thứ bất hợp pháp hoặc nguy hiểm như rượu và ma túy\nCờ bạc, cá cược hoặc trò chơi may rủi để nhận thưởng\nHướng dẫn chế tạo vũ khí trong thế giới thực",
	["Feature.NotApproved.Description.RuleExplanation.BullyingHarassmentDiscrimination"] = "Không nói lời ác ý hay nói xấu người khác, bao gồm việc đe dọa gây hại cho họ, chẳng hạn như bằng cách chia sẻ thông tin riêng tư của họ hoặc làm tổn thương họ ngoài đời thực. \nViệc đối xử tệ với người khác hoặc cô lập họ vì bản chất, niềm tin hoặc xuất thân của họ cũng là trái quy tắc.",
	["Feature.NotApproved.Description.RuleExplanation.Dating"] = "Khi trò chuyện, hãy giữ thái độ thân thiện và không tán tỉnh. Không được phép có các hành vi tình cảm như hôn hoặc hẹn hò. Đồng thời, trang phục của avatar cũng không nên quá hở hang.",
	["Feature.NotApproved.Description.RuleExplanation.DirectingUsersOffPlatform"] = "Việc chia sẻ đường liên kết đến các trang web khác trong cuộc trò chuyện hoặc cho mọi người biết cách tìm hồ sơ của bạn trên các ứng dụng hoặc mạng xã hội khác là vi phạm quy tắc. Nếu có người yêu cầu bạn truy cập một trang web khác, bạn không nên làm theo. Hãy luôn trò chuyện và trải nghiệm trò chơi trên Roblox.\nViệc mua, bán hoặc trao đổi Robux hay các vật phẩm Roblox bên ngoài nền tảng cũng không được chấp nhận.",
	["Feature.NotApproved.Description.RuleExplanation.MisusingRobloxSystems"] = "Việc gian lận, nói dối hoặc chia sẻ cách thực hiện những hành vi đó trên Roblox là vi phạm quy tắc. Ví dụ:",
	["Feature.NotApproved.Description.RuleExplanation.PII"] = "Để giữ an toàn cho mọi người và tài khoản, chúng tôi không cho phép hành vi yêu cầu hoặc chia sẻ thông tin riêng tư, chẳng hạn như:",
	["Feature.NotApproved.Description.RuleExplanation.RealLifeEvents"] = "Việc thiếu tôn trọng đối với những khoảnh khắc cụ thể đã xảy ra ngoài đời thực là hành vi vi phạm quy tắc. Điều này bao gồm hành vi tái hiện hoặc chế giễu các sự kiện hay những người liên quan, đặc biệt khi các sự kiện này khiến nhiều người đau buồn hoặc sợ hãi.\nĐiều này bao gồm:",
	["Feature.NotApproved.Description.RuleExplanation.SSHAndIllegalRegulatedActivities"] = "Không được phép tạo nội dung, nói chuyện hoặc đùa giỡn về những điều nguy hiểm hoặc gây hại, chẳng hạn như:",
	["Feature.NotApproved.Description.RuleExplanation.Spam"] = "Không được phép gửi những tin nhắn lặp đi lặp lại cùng một nội dung.",
	["Feature.NotApproved.Description.RuleExplanation.Swearing"] = "Không dùng lời lẽ thô tục, bao gồm cả việc dùng từ sai chính tả, ký hiệu hoặc cách khác để tránh bị hệ thống phát hiện.",
	["Feature.NotApproved.Description.RuleExplanation.ViolentContentAndGore"] = "Việc thể hiện bạo lực chân thực hoặc bất cứ điều gì trông như một người, động vật hoặc nhân vật bị tổn thương nghiêm trọng về thể chất hoặc tinh thần đều vi phạm quy tắc.",
	["Feature.NotApproved.Description.RuleImportance.BullyingHarassmentDiscrimination"] = "Để duy trì một cộng đồng luôn vui vẻ cho tất cả mọi người, chúng ta không dùng lời nói hoặc hành động khiến người khác cảm thấy không an toàn hoặc khó chịu. Roblox dành cho tất cả chủng tộc, sắc tộc, bản dạng giới, khả năng, xu hướng tính dục và tôn giáo.",
	["Feature.NotApproved.Description.RuleImportance.Dating"] = "Giữ nội dung trò chuyện và avatar tập trung vào tình bạn giúp mọi người cảm thấy thoải mái.",
	["Feature.NotApproved.Description.RuleImportance.DirectingUsersOffPlatform"] = "Roblox có những biện pháp bảo vệ để đảm bảo các cuộc trò chuyện và tương tác luôn được an toàn. Các đường liên kết có thể dẫn bạn đến những trang web giả mạo trông giống hệt Roblox để đánh cắp tài khoản và vật phẩm của bạn. Những trang web đó cũng có thể chứa hình ảnh hoặc video không phù hợp. Nếu bạn trao đổi Robux hoặc vật phẩm bên ngoài Roblox, người khác có thể nói dối và không đưa cho bạn những thứ mà họ đã hứa.",
	["Feature.NotApproved.Description.RuleImportance.MisuingRobloxSystems"] = "Roblox sẽ luôn là một không gian vui vẻ cho tất cả mọi người nếu chúng ta cùng tuân thủ quy tắc và chơi trung thực để không ai có lợi thế không công bằng.",
	["Feature.NotApproved.Description.RuleImportance.MisusingRobloxSystems"] = "Roblox sẽ luôn là một không gian vui vẻ cho tất cả mọi người nếu chúng ta cùng tuân thủ quy tắc và chơi trung thực để không ai có lợi thế không công bằng.",
	["Feature.NotApproved.Description.RuleImportance.PII"] = "Nếu người lạ biết bạn là ai ngoài đời, họ có thể cố gắng liên hệ với bạn ngoài Roblox. Điều này có thể gây nguy hiểm vì trên mạng rất khó phân biệt được người tốt hay người xấu, nên chúng ta không bao giờ chia sẻ mật khẩu. Ai đó có thể đánh cắp tài khoản và mọi thứ bạn kiếm được.",
	["Feature.NotApproved.Description.RuleImportance.RealLifeEvents"] = "Với người từng trải qua những sự kiện này, việc nhìn thấy chúng được tái hiện hoặc đem ra đùa cợt có thể khiến họ bị tổn thương sâu sắc.",
	["Feature.NotApproved.Description.RuleImportance.SSHAndIllegalRegulatedActivities"] = "Chia sẻ nội dung về việc làm hại bản thân hoặc người khác là không an toàn. Nếu bạn đang gặp khó khăn, hãy nói chuyện với một người lớn mà bạn tin tưởng. Việc chia sẻ những thử thách nguy hiểm có thể khiến người khác bắt chước và bị thương nặng. Khi không chia sẻ những nội dung đó, bạn đang góp phần giữ an toàn cho bản thân và mọi người trên Roblox.",
	["Feature.NotApproved.Description.RuleImportance.Spam"] = "Spam làm bạn khó theo dõi các cuộc trò chuyện và làm mọi người mất vui.",
	["Feature.NotApproved.Description.RuleImportance.Swearing"] = "Roblox dành cho tất cả mọi người, bao gồm trẻ nhỏ. Chúng tôi sử dụng từ ngữ tôn trọng và thân thiện cho toàn bộ cộng đồng.",
	["Feature.NotApproved.Description.RuleImportance.ViolentContentAndGore"] = "Cộng đồng của chúng ta có cả trẻ nhỏ và việc chứng kiến cảnh bạo lực cực đoan có thể khiến các em cảm thấy sợ hãi và buồn bã.",
	["Feature.NotApproved.Description.SecondChance.Details"] = "Bạn có thể quay lại chơi ngay bây giờ. Bạn sẽ không thể kháng nghị quyết định này thêm nữa.",
	["Feature.NotApproved.Description.SecondChance.Second"] = "Lần này bạn có thể tránh bị đình chỉ vì đã hành xử có trách nhiệm trong quá khứ.",
