	["Common.UGCValidation.ErrorLabel.HrdCheck_UndefinedInstanceInBoneTree"] = "Die Instanz {instName} der Klasse {className} befindet sich in einem Knochenbaum, ist aber nicht Teil des definierten R15plus-Schemas.",
	["Common.UGCValidation.ErrorLabel.HrdImproperJointMapping"] = "Die optionale Verbindung {jointName} ist in HRD falsch zugeordnet. Sie muss einem Knochen mit dem Namen {boneName} zugeordnet werden.",
	["Common.UGCValidation.ErrorLabel.HrdMissingStandardJoint"] = "Die Verbindung {jointName} ist eine Standard-R15-Verbindung, aber die Rig-Befestigung ist nicht mit HRD verbunden. Stelle sicher, dass HRD unter deinem Avatar mit einem AttachmentConstraint und nicht mit Motor6d verknüpft ist.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_MinAboveMax"] = "{jointName} hat einen in der HRD festgelegten Bereich, aber es gibt eine Komponente im Minimalbereich, die größer als der Maximalbereich ist, was keinen gültigen Bereich darstellt.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_OriginOutsideBounds"] = "Die HumanoidRigDescription hat einen originOffset außerhalb der Grenzen. Der originOffset darf keine Rotation aufweisen und muss zwischen {valueMin} und {valueMax} liegen.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_PropertyOutOfRange"] = "{jointName} {propertyName} ist in der HRD/DRD auf {currentValue} festgelegt. Der zulässige Bereich liegt zwischen {valueMin} und {valueMax}.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_UncontainedJoint"] = "Auf die HRD-Eigenschaft {jointName} wird von der Instanz innerhalb von {foundMeshName} verwiesen, sie ist jedoch nicht Teil der enthaltenen Liste. Wenn du aus Studio veröffentlichst und nur über die HRD/DRD auf Avatarebene verfügst, erstelle bitte einen Fehlerbericht.",
	["Common.UGCValidation.ErrorLabel.HrdTposePosition"] = "Die Verbindung {jointName} hat eine TposeAdjustment-Position, die außerhalb der zulässigen Grenzen liegt. Bitte reduziere den Versatz so, dass er innerhalb von ±({offsetLimit}) liegt.",
	["Common.UGCValidation.ErrorLabel.HrdTposeRotation"] = "Die Verbindung {jointName} hat eine TposeAdjustment-Einstellung, die um mehr als {degLimit}\194\160Grad von der empfohlenen Ausrichtung ({expectedOrientation}) abweicht.",
