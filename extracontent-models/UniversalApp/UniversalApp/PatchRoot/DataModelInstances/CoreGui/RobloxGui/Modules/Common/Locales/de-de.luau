	["Common.UGCValidation.ErrorLabel.InternalError"] = "Dein Objekt konnte aufgrund eines internen Fehlers nicht ordnungsgemäß validiert werden. Wenn dieses Problem weiterhin besteht, erstelle bitte einen Fehlerbericht. ValidationJobId: {ValidationJobId}",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_Moved"] = "{instPath} ist eine verschobene jointRotation, aber Marktplatz-Uploads passen diese Instanz möglicherweise noch nicht an. Bitte setze die Position auf {expectedPosition} zurück.",
