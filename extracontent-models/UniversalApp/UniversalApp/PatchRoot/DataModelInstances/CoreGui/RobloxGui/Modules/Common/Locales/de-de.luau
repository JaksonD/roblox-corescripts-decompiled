	["Common.UGCValidation.ErrorLabel.AssetSchemaUnexpectedItems"] = "Die folgenden Instanzen sind nicht Teil des genehmigten Schemas und sollten entfernt werden: {UnexpectedDescendantPaths}.",
	["Common.UGCValidation.ErrorLabel.AssetSchemaWrongRootClass"] = "Das hochgeladene Objekt sollte ein {ExpectedClass} sein, ist aber ein {RootClass}.",
	["Common.UGCValidation.ErrorLabel.AssetSchemaWrongRootName"] = "Das hochgeladene Objekt sollte den Namen {ExpectedClass} haben, hat aber stattdessen den Namen {RootClass}.",
	["Common.UGCValidation.ErrorLabel.DynamicHeadCageMisaligned"] = "Dynamische Köpfe auf dem Marktplatz müssen ordnungsgemäß gecaged sein, damit die Augen- und Mundscheitelpunkte auf dem Cage mit den Mesh-Scheitelpunkten übereinstimmen. Bitte verbessere deine Cages und deren Ausrichtung mit dem Netz.",
	["Common.UGCValidation.ErrorLabel.DynamicHeadHappyNotShown"] = "Der Ausdruck \"Lächeln\" für den dynamischen Kopf kann nicht erkannt werden. Bitte passe die Cage-Orientierungspunkte für den Mund so an, dass sie mit der Position des Mundes auf dem Kopf übereinstimmen, und stelle sicher, dass er den Ausdruck \"Lächeln\" zeigen kann.",
	["Common.UGCValidation.ErrorLabel.DynamicHeadLeftEyeNotClose"] = "Der Ausdruck \"Linkes Auge geschlossen\" kann für den dynamischen Kopf nicht erkannt werden. Bitte passe die Cage-Orientierungspunkte für das linke Auge so an, dass sie mit der Position des linken Auges auf dem Kopf übereinstimmen, und stelle sicher, dass es geschlossen werden kann.",
	["Common.UGCValidation.ErrorLabel.DynamicHeadMISSINGCAGE"] = "Für dynamische Köpfe auf dem Marktplatz sind keine Kopf-Cages angegeben. Bitte erstelle einen Kopf-Cage für den dynamischen Kopf.",
	["Common.UGCValidation.ErrorLabel.DynamicHeadMouthNotOpen"] = "Der Ausdruck \"Geöffneter Mund\" kann für den dynamischen Kopf nicht erkannt werden. Bitte passe die Cage-Orientierungspunkte für den Mund so an, dass sie mit der Position des Mundes auf dem Kopf übereinstimmen, und stelle sicher, dass er sich öffnen kann.",
	["Common.UGCValidation.ErrorLabel.DynamicHeadNOFACS"] = "Für dynamische Köpfe auf dem Marktplatz sind keine FACS-Daten angegeben.",
	["Common.UGCValidation.ErrorLabel.DynamicHeadRightEyeNotClose"] = "Der Ausdruck \"Rechtes Auge geschlossen\" kann für den dynamischen Kopf nicht erkannt werden. Bitte passe die Cage-Orientierungspunkte für das rechte Auge so an, dass sie mit der Position des rechten Auges auf dem Kopf übereinstimmen, und stelle sicher, dass es geschlossen werden kann.",
	["Common.UGCValidation.ErrorLabel.DynamicHeadSadNotShown"] = "Der Ausdruck \"Stirnrunzeln\" für den dynamischen Kopf kann nicht erkannt werden. Bitte passe die Cage-Orientierungspunkte für den Mund so an, dass sie mit der Position des Mundes auf dem Kopf übereinstimmen, und stelle sicher, dass er den Ausdruck \"Stirnrunzeln\" zeigen kann.",
	["Common.UGCValidation.ErrorLabel.FaceControlsOverrideFACSNotEmpty"] = "Die Eigenschaft InternalOverrideFACSData auf FaceControls muss beim Hochladen leer sein.",
	["Common.UGCValidation.ErrorLabel.FacsExpandsHead"] = "Wir haben festgestellt, dass FACS deinen Kopf auf {modPercent}\194\160% vergrößert hat. Die Änderung des Kopfes verstößt jedoch gegen die Marktplatzrichtlinien für Gesichtsanimationen.",
	["Common.UGCValidation.ErrorLabel.FacsShrinksHead"] = "Wir haben festgestellt, dass FACS deinen Kopf auf {modPercent}\194\160% verkleinert hat. Die Änderung des Kopfes verstößt jedoch gegen die Marktplatzrichtlinien für Gesichtsanimationen.",
	["Common.UGCValidation.ErrorLabel.FailureWithoutReason"] = "Die Validierung ist aus einem unbekannten Grund fehlgeschlagen. Bitte versuche es erneut oder öffne einen Fehlerbericht, wenn dieses Problem weiterhin besteht.",
	["Common.UGCValidation.ErrorLabel.FolderStructureMismatch"] = "Das Upload-Format stimmt nicht mit der erwarteten Ordnerstruktur überein. Bitte versuche es erneut oder erstelle einen Fehlerbericht.",
	["Common.UGCValidation.ErrorLabel.HeadNotDynamic"] = "Dynamische Köpfe auf dem Marktplatz müssen so eingerichtet sein, dass sie die wichtigsten Gesichtsbewegungen richtig animieren, bei deinem Modell wurde jedoch keine wesentliche Veränderung erkannt.",
	["Common.UGCValidation.ErrorLabel.HrdBone_OutOfBounds"] = "Der Knochen {bonePath} liegt zu weit außerhalb des Mesh-Teils {partName}. Bitte platziere ihn näher an der Größenbegrenzung des Mesh-Teils.",
	["Common.UGCValidation.ErrorLabel.HrdBone_TooCloseToParent"] = "Der Knochen {bonePath} liegt zu nahe an seinem übergeordneten Knochen. Passe die Position des Knochens leicht an.",
	["Common.UGCValidation.ErrorLabel.HrdBone_TransformNotIdentity"] = "Der Knochen {bonePath} hat eine Transform-Eigenschaft, die jedoch noch nicht für Marktplatz-Uploads aktiviert ist. Bitte setze sie auf den Identitäts-CFrame zurück.",
	["Common.UGCValidation.ErrorLabel.HrdCheck_BoneNotMappedInHRD"] = "Der Knochen {boneName} ist zulässig, du musst ihn aber explizit in der HumanoidRigDescription oder der DigitRigDescription zuordnen.",
	["Common.UGCValidation.ErrorLabel.HrdCheck_BoneWithoutHrd"] = "Knochen an der Stelle {bonePath} gefunden. Um Knochen nutzen zu können, musst du aber HumanoidRigDescription verwenden.",
	["Common.UGCValidation.ErrorLabel.HrdCheck_DrdInvalidSide"] = "Die DigitsRigDescription in {partName} sollte für die Seite {expectedSide} gelten, aber der Wert der Eigenschaft ist {foundSide}.",
	["Common.UGCValidation.ErrorLabel.HrdCheck_DrdWithoutHrd"] = "Du kannst keine DigitsRigDescription ohne eine HumanoidRigDescription einbeziehen",
	["Common.UGCValidation.ErrorLabel.HrdCheck_DuplicateInstance"] = "Die Instanz {instName} taucht mehr als einmal auf, darf aber innerhalb einer Knochenhierarchie nur einmal vorkommen.",
