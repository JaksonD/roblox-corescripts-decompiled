	["Common.UGCValidation.ErrorLabel.JointRotAtt_UnrecognizedParent"] = "Die Instanz {parentPath} hat ein untergeordnetes JointRotation-Element, das jedoch nicht Teil des zulässigen R15plus-Schemas ist.",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_WrongInstanceClass"] = "Die Instanz {instPath} heißt JointRotation, aber JointRotation ist für Anhänge reserviert, die untergeordnete Elemente eines Anhangs sind.",
	["Common.UGCValidation.ErrorLabel.LCDeformTooLarge"] = "Deine mehrschichtige Kleidung verformt sich über die zulässige Größe von {maxSize}, wenn sie auf einem Avatar angebracht wird.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceAvatar_CageInsideMesh"] = "Der Körper-Cage überschneidet sich mit dem Körper-Mesh. {negtiveSDFPercent}\194\160% der Eckpunkte des Körper-Cages befinden sich innerhalb des Körper-Mesh.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceAvatar_CageTooFar"] = "Der Kopf-Cage ist zu weit vom Körper-Mesh entfernt. Der maximale Abstand zwischen Körper-Cage und Mesh beträgt {max_sdf}, was über dem zulässigen Grenzwert von {max_sdf_threshold} liegt.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceHead_CageInsideMesh"] = "Der Kopf-Cage überschneidet sich mit dem Kopf-Mesh. {negtiveSDFPercent}\194\160% der Eckpunkte des Kopf-Cages befinden sich innerhalb des Kopf-Mesh.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceHead_CageTooFar"] = "Der Kopf-Cage ist zu weit vom Kopf-Mesh entfernt. Der maximale Abstand zwischen Kopf-Cage und Mesh beträgt {max_sdf}, was über dem zulässigen Grenzwert von {max_sdf_threshold} liegt",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistance_CageInsideMesh"] = "Der äußere Cage überschneidet sich mit dem Render-Mesh. {negtiveSDFPercent}\194\160% der Eckpunkte des äußeren Cages liegen innerhalb des Render-Mesh.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistance_CageTooFar"] = "Der äußere Cage ist zu weit vom Render-Mesh entfernt. Der maximale Abstand zwischen äußerem Cage und Mesh beträgt {max_sdf}, was über dem zulässigen Grenzwert von {max_sdf_threshold} liegt.",
	["Common.UGCValidation.ErrorLabel.MeasureCageRelevancy"] = "{outer_cage_face_irrelevant_percent}\194\160% der geänderten Eckpunkte des äußeren Cages decken das Accessoire nicht ab. Achte darauf, den äußeren Cage nur dort zu verschieben, wo es erforderlich ist.",
	["Common.UGCValidation.ErrorLabel.MeasureCageUV"] = "Es gibt {incorrect_uv_count}\194\160UV-Werte im Cage {cage_name}, die falsch sind oder nicht zur Vorlage gehören. Bitte korrigiere die Cage-UV.",
