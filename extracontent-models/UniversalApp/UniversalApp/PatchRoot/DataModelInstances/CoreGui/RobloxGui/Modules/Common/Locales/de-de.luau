	["Common.UGCValidation.ErrorLabel.AccessorySkinning_NotLeaderOrFollower"] = "Der Ziehpunkt hat einen Skin für die Verbindung {jointName}, aber für dieses Objekt muss ein automatischer Skin erstellt werden. Du kannst nur einen Skin für {validJointNameList} erstellen.",
	["Common.UGCValidation.ErrorLabel.AccessorySkinning_RequiredSkinningTransfer"] = "{assetType} muss Skinning-Transfer verwenden. Bitte lege WrapLayer.AutoSkin auf EnabledOverride fest.",
	["Common.UGCValidation.ErrorLabel.AccessorySkinning_RigidIsSkinned"] = "Das starre Accessoire enthält Skinning-Daten, die nicht unterstützt werden. Achte darauf, dass die Knochen nicht zusammen mit dem Mesh importiert werden.",
	["Common.UGCValidation.ErrorLabel.AccessorySkinning_TransferJointWithoutAutoSkin"] = "Der Ziehpunkt enthält die Verbindung {jointName}, die nur zulässig ist, wenn WrapLayer.AutoSkin auf EnabledOverride festgelegt ist.",
