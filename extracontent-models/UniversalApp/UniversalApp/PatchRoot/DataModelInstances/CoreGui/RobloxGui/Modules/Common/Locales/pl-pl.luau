	["Common.UGCValidation.ErrorLabel.HrdCheck_ImproperParent"] = "Element nadrzędny instancji {instName} to {parentName}, ale na podstawie Twoich istniejących kości elementem nadrzędnym powinien być {expectedParentName}.",
	["Common.UGCValidation.ErrorLabel.HrdCheck_UndefinedInstanceInBoneTree"] = "Instancja {instName} klasy {className} znajduje się w drzewie kości, ale nie jest częścią zdefiniowanego schematu R15plus.",
	["Common.UGCValidation.ErrorLabel.HrdImproperJointMapping"] = "Opcjonalny staw {jointName} jest nieprawidłowo zmapowany w HRD. Musi on zostać zmapowany do kości o nazwie {boneName}.",
