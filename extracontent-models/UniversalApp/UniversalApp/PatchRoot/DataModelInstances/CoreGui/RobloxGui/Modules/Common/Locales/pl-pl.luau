	["Common.UGCValidation.ErrorLabel.InternalError"] = "Nie udało się poprawnie zweryfikować Twojego zasobu z powodu błędu wewnętrznego. Jeśli problem nie ustąpi, zgłoś błąd. Identyfikator zadania weryfikacji: {ValidationJobId}",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_Moved"] = "{instPath} to przesunięta instancja jointRotation, ale przesyłane zasoby z rynku mogą jeszcze nie dostosowywać tej instancji. Zresetuj pozycję do {expectedPosition}.",
