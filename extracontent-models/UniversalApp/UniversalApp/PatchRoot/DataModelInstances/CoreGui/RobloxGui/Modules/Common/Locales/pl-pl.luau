	["Common.UGCValidation.ErrorLabel.HrdProperties_MinAboveMax"] = "{jointName} ma zakres ustawiony w HRD, ale w zakresie minimalnym znajduje się komponent o wartości większej niż zakres maksymalny, co nie jest prawidłowym zakresem.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_OriginOutsideBounds"] = "Właściwość HumanoidRigDescription ma wartość originOffset poza zakresem. Właściwość originOffset nie może mieć obrotu i musi mieścić się w przedziale od {valueMin} do {valueMax}.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_PropertyOutOfRange"] = "W HRD/DRD parametr {jointName} {propertyName} jest ustawiony na {currentValue}. Dopuszczalny zakres to od {valueMin} do {valueMax}.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_UncontainedJoint"] = "Instancja w {foundMeshName} odwołuje się do właściwości HRD {jointName}, ale nie jest ona częścią zawartej listy. Jeśli publikujesz z aplikacji Studio i masz HRD/DRD tylko na poziomie awatara, zgłoś błąd.",
	["Common.UGCValidation.ErrorLabel.HrdTposePosition"] = "Położenie właściwości TposeAdjustment stawu {jointName} znajduje się poza dopuszczalnym zakresem. Zmniejsz przesunięcie, aby mieściło się w przedziale ok. {offsetLimit}.",
	["Common.UGCValidation.ErrorLabel.HrdTposeRotation"] = "Staw {jointName} ma wartość TposeAdjustment, która odbiega o więcej niż {degLimit} stopni od zalecanej orientacji {expectedOrientation}.",
