	["Common.UGCValidation.ErrorLabel.JointRotAtt_WrongInstanceClass"] = "Instancja {instPath} nosi nazwę JointRotation, ale nazwa JointRotation jest zarezerwowana dla punktów zaczepienia, które są elementami podrzędnymi innego zaczepienia.",
	["Common.UGCValidation.ErrorLabel.LCDeformTooLarge"] = "Po założeniu na awatara warstwowa odzież odkształca się, przekraczając dopuszczalny rozmiar {maxSize}.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceAvatar_CageInsideMesh"] = "Obramowanie ciała przecina się z siatką ciała. {negtiveSDFPercent}% wierzchołków obramowania ciała znajduje się wewnątrz siatki ciała.",
