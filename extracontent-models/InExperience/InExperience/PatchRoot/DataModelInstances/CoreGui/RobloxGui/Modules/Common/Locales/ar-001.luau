	["Common.UGCValidation.ErrorLabel.HrdCheck_UndefinedInstanceInBoneTree"] = "الحالة {instName} من الفئة {className} موجودة في شجرة عظام ولكنها ليست جزءًا من مخطط R15plus المحدد.",
	["Common.UGCValidation.ErrorLabel.HrdImproperJointMapping"] = "تم تعيين المفصل الاختياري {jointName} بشكل غير صحيح في HRD. يجب تعيينه إلى عظم يسمى {boneName}.",
	["Common.UGCValidation.ErrorLabel.HrdMissingStandardJoint"] = "المفصل {jointName} هو مفصل R15 قياسي، لكن ملحق نقطة الاتصال غير متصل بـ HRD. تأكد من أن HRD الموجود تحت الأفاتار الخاص بك مرتبط بـ AttachmentConstraint وليس بـ Motor6d.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_MinAboveMax"] = "تم إعداد نطاق لـ {jointName} في HRD، لكن أحد مكوناته في الحد الأدنى أكبر من الحد الأقصى، وهذا لا يُعد نطاقًا صالحًا.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_OriginOutsideBounds"] = "يحتوي HumanoidRigDescription على OriginOffset خارج الحدود. يجب ألا يحتوي OriginOffset على أي دوران، ويجب أن يكون ضمن {valueMin} و{valueMax}.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_PropertyOutOfRange"] = "تم إعداد {jointName} لخاصية {propertyName} في HRD/DRD إلى {currentValue}. النطاق المقبول هو من {valueMin} إلى {valueMax}.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_UncontainedJoint"] = "تتم الإشارة إلى خاصية HRD {jointName} بواسطة الحالة الموجودة ضمن {foundMeshName}، لكن هذه الخاصية غير مدرجة في القائمة المحتواة. إذا كنت تنشر من Studio ولديك HRD/DRD فقط على مستوى الأفاتار، يُرجى الإبلاغ عن الأخطاء.",
	["Common.UGCValidation.ErrorLabel.HrdTposePosition"] = "يحتوي المفصل {jointName} على موضع TposeAdjustment خارج الحدود المقبولة. يُرجى تقليل الإزاحة بحيث تكون ضمن +-({offsetLimit}).",
	["Common.UGCValidation.ErrorLabel.HrdTposeRotation"] = "يحتوي المفصل {jointName} على موضع TposeAdjustment ينحرف بأكثر من {degLimit} من الدرجات عن الاتجاه المُقترح {expectedOrientation}.",
	["Common.UGCValidation.ErrorLabel.InstanceTagsFound"] = "تحتوي الحالات التالية على وسوم ولكن أصول السوق لا يمكن أن تحتوي على أي وسوم: {ProblematicDescendantPaths}",
	["Common.UGCValidation.ErrorLabel.InternalError"] = "تعذّر التحقق من صحة الأصل بشكل صحيح بسبب خطأ داخلي. إذا استمرت هذه المشكلة، يُرجى إنشاء بلاغ عن الأخطاء. ValidationJobId: {ValidationJobId}",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_Moved"] = "الحالة {instPath} هي jointRotation تم تحريكه، لكن رفع العناصر على المتجر قد لا يسمح بعد بتعديل هذه الحالة. يُرجى إعادة تعيين الموضع إلى {expectedPosition}.",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_MultipleAttachments"] = "لا يمكن أن تحتوي الحالة {parentPath} على أكثر من عنصر فرعي واحد من نوع JointRotation.",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_Rotated"] = "الحالة {instPath} هي jointRotation، ولكن رفع العناصر على المتجر قد لا يسمح بعد بتعديل هذه الحالة. يرجى إعادة تعيين الاتجاه إلى {expectedOrientation}.",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_UnrecognizedParent"] = "تحتوي الحالة {parentPath} على عنصر فرعي من نوع JointRotation، ولكن هذا ليس جزءًا من مخطط R15plus المسموح به.",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_WrongInstanceClass"] = "الحالة {instPath} تسمى JointRotation ولكن JointRotation محجوز لنقاط الاتصال التي هي أجزاء فرعية لنقطة اتصال أخرى.",
	["Common.UGCValidation.ErrorLabel.LCDeformTooLarge"] = "تتشوه الملابس ذات الطبقات الخاصة بك بما يتجاوز الحجم المقبول البالغ {maxSize} عند وضعها على الأفاتار.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceAvatar_CageInsideMesh"] = "يتقاطع قفص الجسم مع mesh الجسم. {negtiveSDFPercent}% من قمم قفص الجسم تقع داخل mesh الجسم.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceAvatar_CageTooFar"] = "قفص الرأس بعيد جدًا عن mesh الرأس. يبلغ الحد الأقصى للمسافة بين قفص الرأس و {max_sdf}، وهو أعلى من الحد المسموح به {max_sdf_threshold}",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceHead_CageInsideMesh"] = "يتقاطع قفص الرأس مع mesh الرأس. {negtiveSDFPercent}% من قمم قفص الرأس تقع داخل mesh الرأس.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceHead_CageTooFar"] = "قفص الرأس بعيد جدًا عن mesh الرأس. يبلغ الحد الأقصى للمسافة بين قفص الرأس وmesh {max_sdf}، وهو أعلى من الحد المسموح به {max_sdf_threshold}",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistance_CageInsideMesh"] = "يتقاطع القفص الخارجي مع mesh العرض. {negtiveSDFPercent}% من قمم القفص الخارجي تقع داخل mesh العرض.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistance_CageTooFar"] = "القفص الخارجي بعيد جدًا عن mesh العرض. يبلغ الحد الأقصى للمسافة بين القفص الخارجي وmesh {max_sdf}، وهو أعلى من الحد المسموح به {max_sdf_threshold}",
	["Common.UGCValidation.ErrorLabel.MeasureCageRelevancy"] = "{outer_cage_face_irrelevant_percent}% من رؤوس القفص الخارجي المُعدَّلة لا تغطي الإكسسوار. تأكد من تحريك القفص الخارجي فقط عند الحاجة.",
	["Common.UGCValidation.ErrorLabel.MeasureCageUV"] = "توجد {incorrect_uv_count} قيم UV في القفص {cage_name} غير صحيحة أو لا تنتمي إلى القالب. يرجى تصحيح قيم UV للقفص.",
	["Common.UGCValidation.ErrorLabel.MeasureMeshOutsideOuterCage"] = "{mesh_outside_outer_cage_percent}% من قمم mesh الخاصة بالإكسسوار تقع خارج قفصه الخارجي. قم بإجراء تعديلات لوضع جزء أكبر من الإكسسوار بين الأقفاص.",
	["Common.UGCValidation.ErrorLabel.MissingRequiredAttachment"] = "يجب أن توجد نقطة الاتصال {attName} مرة واحدة بالضبط ضمن العناصر الفرعية للجزء {partName}.",
	["Common.UGCValidation.ErrorLabel.NoAttributes"] = "يحتوي '{RootInstanceName}' (أو العناصر الفرعية له) على سمات. يتعين عليك إزالة السمات مما يلي: {InstanceNameList}",
	["Common.UGCValidation.ErrorLabel.SelectionCountNotOne"] = "لرفع أصل على منصة Roblox، يجب عليك تحديد حالة واحدة بالضبط ونوع الرفع المرتبط بها.",
	["Common.UGCValidation.ErrorLabel.UnallowedFacsJoints"] = "يحتوي MeshPart الخاص بالرأس على محرك وجه لـ {jointName}، والذي لا يمكن استخدامه في نظام FACs. يُرجى إعادة تسمية هذه المفصل ثم إعادة استيراد الرأس.",
