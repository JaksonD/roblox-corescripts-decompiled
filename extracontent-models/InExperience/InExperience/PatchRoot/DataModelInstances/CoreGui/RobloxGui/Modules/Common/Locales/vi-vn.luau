	["Common.UGCValidation.ErrorLabel.FolderStructureMismatch"] = "Định dạng của tệp tải lên không khớp với cấu trúc thư mục yêu cầu. Vui lòng thử lại hoặc gửi báo cáo lỗi.",
	["Common.UGCValidation.ErrorLabel.HeadNotDynamic"] = "Đầu hiệu ứng động trên chợ phải được thiết lập sao cho tạo hiệu ứng động thích hợp cho các cử động cơ bản trên khuôn mặt, nhưng hệ thống phát hiện của chúng tôi không nhận ra thay đổi nào đáng kể.",
	["Common.UGCValidation.ErrorLabel.HrdBone_OutOfBounds"] = "Xương {bonePath} nằm quá xa so với meshpart {partName}, vui lòng đặt xương này gần hơn với ranh giới kích thước của meshpart.",
	["Common.UGCValidation.ErrorLabel.HrdBone_TooCloseToParent"] = "Xương {bonePath} nằm quá gần xương cha của xương đó. Hãy điều chỉnh vị trí của xương này một chút.",
	["Common.UGCValidation.ErrorLabel.HrdBone_TransformNotIdentity"] = "Xương {bonePath} có thuộc tính biến đổi, nhưng thuộc tính này chưa được kích hoạt khi tải lên chợ. Vui lòng đặt lại xương này về CFrame mặc định.",
	["Common.UGCValidation.ErrorLabel.HrdCheck_BoneNotMappedInHRD"] = "Được phép sử dụng Xương {boneName}, nhưng bạn phải ánh xạ cụ thể xương này trong HumanoidRigDescription hoặc DigitsRigDescription.",
	["Common.UGCValidation.ErrorLabel.HrdCheck_BoneWithoutHrd"] = "Đã tìm thấy Xương tại {bonePath}, nhưng bạn phải dùng HumanoidRigDescription để sử dụng Xương.",
	["Common.UGCValidation.ErrorLabel.HrdCheck_DrdInvalidSide"] = "DigitsRigDescription bên trong {partName} lẽ ra phải thuộc về bên {expectedSide}, nhưng giá trị thuộc tính hiện tại lại là {foundSide}.",
	["Common.UGCValidation.ErrorLabel.HrdCheck_DrdWithoutHrd"] = "Bạn không được thêm DigitsRigDescription mà không có HumanoidRigDescription.",
	["Common.UGCValidation.ErrorLabel.HrdCheck_DuplicateInstance"] = "Đối tượng {instName} xuất hiện nhiều lần, nhưng chỉ được phép tồn tại một lần trong hệ thống phân cấp xương.",
	["Common.UGCValidation.ErrorLabel.HrdCheck_ImproperParent"] = "Đối tượng {instName} nằm dưới {parentName}, nhưng dựa trên các Xương hiện có của bạn, đối tượng này phải nằm dưới {expectedParentName}.",
	["Common.UGCValidation.ErrorLabel.HrdCheck_UndefinedInstanceInBoneTree"] = "Đối tượng {instName} của lớp {className} nằm trong một cây xương nhưng không thuộc lược đồ R15plus đã được xác định.",
	["Common.UGCValidation.ErrorLabel.HrdImproperJointMapping"] = "Khớp tùy chọn {jointName} được ánh xạ không chính xác trong HRD. Khớp này phải được ánh xạ tới một xương có tên là {boneName}.",
	["Common.UGCValidation.ErrorLabel.HrdMissingStandardJoint"] = "Khớp {jointName} là khớp R15 tiêu chuẩn, nhưng chỗ đính bộ khung không được kết nối với HRD. Hãy đảm bảo rằng HRD dưới avatar của bạn đang được liên kết với AttachmentConstraint thay vì Motor6d.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_MinAboveMax"] = "{jointName} có phạm vi được đặt trong HRD, nhưng có một thành phần trong phạm vi tối thiểu lớn hơn phạm vi tối đa, đây không phải là phạm vi hợp lệ.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_OriginOutsideBounds"] = "HumanoidRigDescription có originOffset nằm ngoài giới hạn. OriginOffset không được xoay và phải nằm trong khoảng từ {valueMin} đến {valueMax}.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_PropertyOutOfRange"] = "{jointName} {propertyName} được đặt trong HRD/DRD thành {currentValue}. Phạm vi cho phép là từ {valueMin} đến {valueMax}.",
	["Common.UGCValidation.ErrorLabel.HrdProperties_UncontainedJoint"] = "Thuộc tính HRD {jointName} được dẫn chiếu bởi đối tượng trong {foundMeshName}, nhưng không có trong danh sách chứa sẵn. Nếu bạn đang đăng từ studio và chỉ có HRD/DRD ở cấp độ avatar, vui lòng gửi báo cáo lỗi.",
	["Common.UGCValidation.ErrorLabel.HrdTposePosition"] = "Khớp {jointName} có vị trí TposeAdjustment nằm ngoài giới hạn cho phép. Vui lòng giảm offset sao cho nằm trong khoảng +-({offsetLimit}).",
	["Common.UGCValidation.ErrorLabel.HrdTposeRotation"] = "Khớp {jointName} có TposeAdjustment lệch hơn {degLimit} độ so với hướng được đề xuất {expectedOrientation}.",
	["Common.UGCValidation.ErrorLabel.InstanceTagsFound"] = "Các trường hợp sau có gắn thẻ nhưng tài sản trên chợ không được phép gắn thẻ: {ProblematicDescendantPaths}",
	["Common.UGCValidation.ErrorLabel.InternalError"] = "Có lỗi nội bộ dẫn đến việc chúng tôi không thể xác thực tài sản của bạn. Vui lòng tạo báo cáo lỗi nếu sự cố này tiếp diễn. ValidationJobId: {ValidationJobId}",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_Moved"] = "{instPath} là một jointRotation đã được di chuyển, nhưng các bản tải lên trên chợ có thể chưa điều chỉnh đối tượng này. Vui lòng đặt lại vị trí về {expectedPosition}.",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_MultipleAttachments"] = "Đối tượng {parentPath} không được có nhiều hơn 1 JointRotation là con.",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_Rotated"] = "{instPath} là một jointRotation đã được xoay, nhưng các bản tải lên trên chợ có thể chưa điều chỉnh đối tượng này. Vui lòng đặt lại hướng về {expectedOrientation}.",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_UnrecognizedParent"] = "Đối tượng {parentPath} có một JointRotation là con, nhưng phần tử con này lại không có trong lược đồ R15plus được phép sử dụng.",
	["Common.UGCValidation.ErrorLabel.JointRotAtt_WrongInstanceClass"] = "Đối tượng {instPath} được đặt tên là JointRotation, nhưng JointRotation được dành riêng cho các chỗ đính là con của chỗ đính khác.",
	["Common.UGCValidation.ErrorLabel.LCDeformTooLarge"] = "Trang phục nhiều lớp của bạn bị biến dạng vượt quá kích thước cho phép là {maxSize} khi được mặc lên một avatar.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceAvatar_CageInsideMesh"] = "Khung lưới bề mặt và lưới bề mặt của thân giao nhau. {negtiveSDFPercent}% các đỉnh khung lưới bề mặt của thân nằm bên trong lưới bề mặt của thân.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceAvatar_CageTooFar"] = "Khung lưới bề mặt và lưới bề mặt của thân cách nhau quá xa. Khoảng cách tối đa giữa khung lưới bề mặt và lưới bề mặt của thân là {max_sdf}, cao hơn ngưỡng cho phép {max_sdf_threshold}",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceHead_CageInsideMesh"] = "Khung lưới bề mặt và lưới bề mặt của đầu giao nhau. {negtiveSDFPercent}% các đỉnh khung lưới bề mặt của đầu nằm bên trong lưới bề mặt của đầu.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistanceHead_CageTooFar"] = "Khung lưới bề mặt và lưới bề mặt của đầu cách nhau quá xa. Khoảng cách tối đa giữa khung lưới bề mặt và lưới bề mặt của đầu là {max_sdf}, cao hơn ngưỡng cho phép {max_sdf_threshold}",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistance_CageInsideMesh"] = "Khung lưới bề mặt ngoài và lưới bề mặt kết xuất giao nhau. {negtiveSDFPercent}% các đỉnh của khung lưới bề mặt ngoài nằm bên trong lưới bề mặt kết xuất.",
	["Common.UGCValidation.ErrorLabel.MeasureCageMeshDistance_CageTooFar"] = "Khung lưới bề mặt ngoài và lưới bề mặt kết xuất cách nhau quá xa. Khoảng cách tối đa giữa khung lưới bề mặt ngoài và lưới bề mặt kết xuất là {max_sdf}, cao hơn ngưỡng cho phép {max_sdf_threshold}",
	["Common.UGCValidation.ErrorLabel.MeasureCageRelevancy"] = "{outer_cage_face_irrelevant_percent}% các đỉnh của lồng ngoài đã sửa đổi không bao phủ phụ kiện. Hãy đảm bảo bạn chỉ di chuyển lồng ngoài ở những vị trí cần thiết.",
	["Common.UGCValidation.ErrorLabel.MeasureCageUV"] = "Có {incorrect_uv_count} giá trị UV trong khung lưới {cage_name} không chính xác hoặc không thuộc về mẫu. Vui lòng sửa UV của khung lưới.",
	["Common.UGCValidation.ErrorLabel.MeasureMeshOutsideOuterCage"] = "{mesh_outside_outer_cage_percent}% các đỉnh của lưới bề mặt dành cho phụ kiện nằm bên ngoài khung lưới bề mặt ngoài của phụ kiện đó. Hãy điều chỉnh để phụ kiện được đặt trong các khung lưới bề mặt nhiều hơn.",
	["Common.UGCValidation.ErrorLabel.MissingRequiredAttachment"] = "Chỗ đính {attName} phải tồn tại duy nhất một lần trong các mục con của {partName}.",
	["Common.UGCValidation.ErrorLabel.NoAttributes"] = "\"{RootInstanceName}\" (hoặc các mục con) có chứa Thuộc tính. Bạn cần xóa Thuộc tính khỏi các mục sau: {InstanceNameList}",
	["Common.UGCValidation.ErrorLabel.SelectionCountNotOne"] = "Để tải một tài sản lên Roblox, bạn phải chọn chính xác 1 trường hợp và loại tải lên tương ứng.",
	["Common.UGCValidation.ErrorLabel.UnallowedFacsJoints"] = "Bộ phận meshpart đầu có các hiệu ứng khuôn mặt cho khớp {jointName}, là khớp không thể sử dụng được trong FAC. Vui lòng đổi tên khớp này, sau đó nhập lại phần đầu của bạn.",
